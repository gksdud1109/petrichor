# === Petrichor 로컬 개발 환경 변수 ===
# ⚠️ 로컬 전용 기본값 — 공유/스테이징 환경에서는 반드시 변경하라.
# 사용: cp .env.example .env  (그리고 docker compose가 이 값을 읽음)

# --- Postgres 컨테이너 ---
POSTGRES_DB=petrichor
POSTGRES_USER=petrichor
POSTGRES_PASSWORD=petrichor
POSTGRES_PORT=5432

# --- Redis 컨테이너 ---
REDIS_PORT=6379

# --- MinIO 컨테이너 (R2 호환 로컬 오브젝트 스토리지) ---
MINIO_ROOT_USER=petrichor
MINIO_ROOT_PASSWORD=petrichor-secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MEDIA_BUCKET=petrichor-media

# === Backend (Spring Boot) — 호스트에서 ./gradlew bootRun 시 ===
SPRING_PROFILES_ACTIVE=local
DB_URL=jdbc:postgresql://localhost:5432/petrichor
DB_USERNAME=petrichor
DB_PASSWORD=petrichor
REDIS_HOST=localhost
REDIS_APP_PORT=6379
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=petrichor
S3_SECRET_KEY=petrichor-secret
S3_BUCKET=petrichor-media
S3_REGION=us-east-1
